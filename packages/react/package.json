{
  "name": "@dotmatter/react",
  "version": "0.3.0",
  "description": "React component for dotmatter \u2014 render any image or video as an interactive particle field: <DotMatter src={img} effect={ditherEffect} />.",
  "keywords": [
    "react",
    "webgl",
    "particles",
    "shader",
    "image-effects",
    "interactive",
    "dither",
    "halftone",
    "ascii"
  ],
  "license": "MIT",
  "author": "Treshnanda <treshnanda@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tresnanda/dotmatter.git"
  },
  "homepage": "https://github.com/Tresnanda/dotmatter#readme",
  "bugs": {
    "url": "https://github.com/Tresnanda/dotmatter/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dotmatter/core": "workspace:*",
    "@dotmatter/shaders": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
